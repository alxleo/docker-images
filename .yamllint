---
# yamllint baseline — synced to all repos.
# Tighter than 'relaxed' but pragmatic for CI/config files.

extends: default

rules:
  # Long lines are common in CI workflows and config files.
  line-length: disable

  # Allow both styles — LLM agents and humans mix freely.
  comments:
    min-spaces-from-content: 1

  # pre-commit-config.yaml and other configs often lack document start.
  document-start: disable

  # Truthy values like 'on:' are everywhere in GHA workflows.
  truthy:
    check-keys: false
