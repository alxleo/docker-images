{
	local_certs
	skip_install_trust
	auto_https disable_redirects
	admin :2019
}

(mcp-routes) {
	handle_path /hackernews/* {
		reverse_proxy mcp-hackernews:8080 {
			health_uri /ping
			health_interval 10s
			flush_interval -1
		}
	}

	handle_path /arxiv/* {
		reverse_proxy mcp-arxiv:8080 {
			health_uri /ping
			health_interval 10s
			flush_interval -1
		}
	}
}

:80 {
	# CORS headers for browser-based MCP clients
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, OPTIONS, DELETE"
		Access-Control-Allow-Headers "Content-Type, Accept, Authorization, Mcp-Session-Id"
		Access-Control-Expose-Headers "Mcp-Session-Id"
	}

	# Chrome Private Network Access (PNA) preflight
	@pna_preflight {
		method OPTIONS
		header Access-Control-Request-Private-Network true
	}
	handle @pna_preflight {
		header Access-Control-Allow-Private-Network "true"
		respond "" 204
	}

	# Accept header fix for MCP SDK quirk — rewrite request header
	# before it reaches mcp-proxy (request_header, not response header)
	@mcp_post {
		method POST
		not header Accept application/json*
		not header Accept text/event-stream*
	}
	request_header @mcp_post Accept "application/json, text/event-stream"

	handle /health {
		respond "OK" 200
	}

	handle /.well-known/mcp.json {
		header Content-Type "application/json"
		respond `{"services":{"hackernews":"/hackernews/","arxiv":"/arxiv/"}}` 200
	}

	import mcp-routes

	handle {
		redir https://github.com/alxleo/docker-images 302
	}
}

https://localhost {
	handle /health {
		respond "OK" 200
	}

	import mcp-routes
}
