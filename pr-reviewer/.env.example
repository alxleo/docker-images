# PR Reviewer — Required and optional environment variables
#
# Required for all modes:
CLAUDE_CODE_OAUTH_TOKEN=        # Claude Max subscription token (CC_TOKEN in host env)

# Required for GitHub mode (gh_watcher.py):
GH_APP_ID=                      # GitHub App ID
GH_APP_INSTALLATION_ID=         # GitHub App installation ID
GH_APP_PRIVATE_KEY=             # PEM private key (use literal \n for newlines in env vars)

# Required for Gitea mode (gitea_webhook.py):
GITEA_URL=http://gitea:3000     # Gitea server URL
GITEA_ORG=ci                    # Gitea organization
GITEA_TOKEN=                    # Gitea API token (for clone + API operations)
WEBHOOK_SECRET=                 # HMAC-SHA256 webhook signing secret

# Optional — multi-model support:
GEMINI_API_KEY=                 # Gemini API key (or mount ~/.gemini/oauth_creds.json for subscription auth)
OPENAI_API_KEY=                 # OpenAI/Codex API key (or mount ~/.codex/auth.json for subscription auth)
